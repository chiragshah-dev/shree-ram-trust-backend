<% content_for :page_title, "Manage Users" %>

<div class="d-flex justify-content-end mb-3">
  <%= link_to new_admin_user_path, class: "btn btn-primary btn-sm", style: "border-radius:8px;" do %>
    <i class="bi bi-plus me-1"></i>Create User
  <% end %>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th class="ps-4">User</th>
          <th>Role</th>
          <th>Status</th>
          <th>Tasks</th>
          <th>Joined</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <%= render 'user_row', user: user %>
        <% end %>
      </tbody>
    </table>
    <div class="px-3 py-2 border-top">
      <%= paginate @users %>
    </div>
  </div>
</div>
