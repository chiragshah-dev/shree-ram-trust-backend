<tr>
  <td class="ps-4">
    <div class="d-flex align-items-center gap-2">
      <div class="user-avatar-sm"><%= user.name[0..1].upcase %></div>
      <div>
        <div style="font-weight:500;font-size:.875rem;"><%= user.name %></div>
        <div style="font-size:.75rem;color:#9ca3af;"><%= user.email %></div>
      </div>
    </div>
  </td>
  <td><span class="badge-status badge-<%= user.role %>"><%= user.role.capitalize %></span></td>
  <td><span class="badge-status badge-<%= user.active? ? 'active' : 'inactive' %>">
    <%= user.active? ? 'Active' : 'Inactive' %>
  </span></td>
  <td><%= "user.tasks.count" %></td>
  <td><span style="font-size:.8rem;color:#6b7280;"><%= user.created_at.strftime('%b %Y') %></span></td>
  <td>
    <%= link_to edit_admin_user_path(user), class: "btn btn-sm btn-outline-secondary me-1",
        style: "border-radius:6px;font-size:.75rem;" do %>
      <i class="bi bi-pencil"></i>
    <% end %>
    <%= button_to toggle_active_admin_user_path(user), method: :patch,
        class: "btn btn-sm btn-outline-#{user.active? ? 'danger' : 'success'}",
        style: "border-radius:6px;font-size:.75rem;" do %>
      <i class="bi bi-<%= user.active? ? 'slash-circle' : 'check-circle' %>"></i>
    <% end %>
  </td>
</tr>
