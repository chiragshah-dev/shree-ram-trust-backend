<div class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon"><i class="bi bi-layers"></i></div>
    TaskFlow
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-title">Main</div>
    <%= link_to admin_dashboard_path, class: "nav-link #{active_link?('admin/dashboard')}" do %>
      <i class="bi bi-grid"></i> Dashboard
    <% end %>

    <% if current_user.admin? %>
      <div class="nav-section-title">Admin</div>
      <%= link_to admin_users_path, class: "nav-link #{active_link?('admin/users')}" do %>
        <i class="bi bi-people"></i> Manage Users
      <% end %>
    <% end %>

    <%= button_to destroy_user_session_path, method: :delete, class: "nav-link btn btn-link w-100 text-start" do %>
      <i class="bi bi-box-arrow-right"></i> Logout
    <% end %>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="avatar"><%= current_user.name[0..1].upcase %></div>
      <div class="user-info">
        <div class="name"><%= current_user.name %></div>
        <div class="role"><%= current_user.role.capitalize %></div>
      </div>
    </div>
  </div>
</div>
