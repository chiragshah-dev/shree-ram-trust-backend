<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; background: #f5f4ff; margin: 0; padding: 0; }
    .container { max-width: 560px; margin: 40px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .header { background: #4f46e5; padding: 32px; text-align: center; }
    .header h1 { color: #fff; margin: 0; font-size: 24px; }
    .body { padding: 32px; }
    .body p { color: #374151; font-size: 15px; line-height: 1.6; }
    .credentials { background: #f5f4ff; border: 1px solid #ede9fe; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .credentials p { margin: 6px 0; color: #374151; font-size: 15px; }
    .credentials strong { color: #4f46e5; }
    .warning { background: #fef3c7; border: 1px solid #fde68a; border-radius: 8px; padding: 14px 18px; margin-top: 16px; }
    .warning p { margin: 0; color: #92400e; font-size: 13px; }
    .footer { text-align: center; padding: 20px; color: #9ca3af; font-size: 12px; border-top: 1px solid #f3f4f6; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Welcome to Shree Ram Trust!</h1>
    </div>
    <div class="body">
      <p>Hi <strong><%= @user.name %></strong>,</p>
      <p>Your account has been created by the administrator. Here are your login credentials:</p>

      <div class="credentials">
        <p><strong>Email:</strong> <%= @user.email %></p>
        <p><strong>Password:</strong> <%= @plain_password %></p>
      </div>

      <div class="warning">
        <p>⚠️ Please change your password immediately after your first login for security.</p>
      </div>

      <p style="margin-top: 24px;">If you have any questions, contact your administrator.</p>
    </div>
    <div class="footer">
      <p>© <%= Date.today.year %> Shree Ram Trust . All rights reserved.</p>
    </div>
  </div>
</body>
</html>
