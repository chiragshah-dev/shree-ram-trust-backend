<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; background: #f5f4ff; margin: 0; padding: 0; }
    .container { max-width: 560px; margin: 40px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .header { background: #4f46e5; padding: 32px; text-align: center; }
    .header h1 { color: #fff; margin: 0; font-size: 24px; }
    .body { padding: 32px; }
    .body p { color: #374151; font-size: 15px; line-height: 1.6; }
    .otp-box { background: #f5f4ff; border: 2px dashed #4f46e5; border-radius: 12px; padding: 24px; text-align: center; margin: 24px 0; }
    .otp-code { font-size: 42px; font-weight: 700; color: #4f46e5; letter-spacing: 10px; }
    .otp-expire { color: #6b7280; font-size: 13px; margin-top: 8px; }
    .footer { text-align: center; padding: 20px; color: #9ca3af; font-size: 12px; border-top: 1px solid #f3f4f6; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Password Reset OTP</h1>
    </div>
    <div class="body">
      <p>Hi <strong><%= @user.name %></strong>,</p>
      <p>We received a request to reset your password. Use the OTP below:</p>

      <div class="otp-box">
        <div class="otp-code"><%= @otp %></div>
        <div class="otp-expire">Expires in 10 minutes</div>
      </div>

      <p>If you did not request a password reset, please ignore this email. Your password will remain unchanged.</p>
    </div>
    <div class="footer">
      <p>© <%= Date.today.year %> Shree Ram Trust. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
